# ─── Razorpay ─────────────────────────────────────────────────────────────────
# Get these from https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_key_secret_here

# ─── Nasdaq Data Link (LBMA Gold price) ───────────────────────────────────────
# Free tier: https://data.nasdaq.com → Account → API Key
# Dataset: LBMA/GOLD (requires free account)
NASDAQ_API_KEY=your_nasdaq_api_key_here

# ─── Polygon / Blockchain ─────────────────────────────────────────────────────
# Private key of the REGISTRAR wallet (funded with MATIC for gas)
REGISTRAR_PRIVATE_KEY=0xYOUR_REGISTRAR_PRIVATE_KEY
# Use amoy for testnet, polygon for mainnet
POLYGON_NETWORK=amoy
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
# Get from https://polygonscan.com/register → API Keys
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
