# ─── TGDP Production Environment ──────────────────────────────────────────────
# Copy this file to .env on your production server and fill in all values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Node ────────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── PostgreSQL ──────────────────────────────────────────────────────────────────
# Full connection string for your production PostgreSQL instance.
# Example: postgresql://tgdp_user:strongpassword@db.example.com:5432/tgdp_prod
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# ── Firebase ────────────────────────────────────────────────────────────────────
# Your Firebase project ID (found in Firebase Console → Project Settings)
FIREBASE_PROJECT_ID=your-project-id

# Path to your Firebase service account JSON key (download from Firebase Console
# → Project Settings → Service Accounts → Generate new private key)
# NEVER commit this file — it is already in .gitignore via **/serviceAccountKey.json
GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/serviceAccountKey.json

# Leave FIREBASE_AUTH_EMULATOR_HOST unset in production (only used locally)
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# ── CORS ─────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slashes)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Blockchain (Polygon) ─────────────────────────────────────────────────────────
# Set to mainnet URL in production if blockchain recording is enabled.
# Leave blank to disable blockchain recording.
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_NETWORK=mainnet
REGISTRAR_PRIVATE_KEY=

# ── LBMA Gold Price ───────────────────────────────────────────────────────────────
# Nasdaq Data Link API key for live gold price feed.
# Get one at: https://data.nasdaq.com/
NASDAQ_API_KEY=

# ── Razorpay ─────────────────────────────────────────────────────────────────────
# Payment gateway credentials (live keys from Razorpay Dashboard)
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=

# ── Pinata (IPFS) ─────────────────────────────────────────────────────────────────
# Only required if design file pinning to IPFS is used.
# Stored in the database config table, not directly in .env.
# Set it via the admin panel → Config → pinataJWT
