# ─── TGDP Local Development Environment ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/tgdp_local

# Firebase project (for Auth emulator token verification)
FIREBASE_PROJECT_ID=tgdp-d4a3d
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# Express server port (default 3001)
PORT=3001

# Polygon / blockchain (optional — blockchain recording is skipped if not set)
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_NETWORK=amoy
REGISTRAR_PRIVATE_KEY=

# LBMA gold price (Nasdaq Data Link API key)
NASDAQ_API_KEY=

# Razorpay payment gateway
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
